#!/usr/bin/env bash
# Claude Custom Manager - Manage custom Claude Code deployments
# Usage: claude-custom <command> [options]

set -e  # Exit on error

# Version
VERSION="1.0.3"

# Configuration
CONFIG_DIR="$HOME/.claude-custom"
CONFIG_FILE="$CONFIG_DIR/config.json"
CLAUDE_MODEL_DIR="$HOME/claude-model"
BIN_DIR="$CONFIG_DIR/bin"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Initialize configuration directory and file
init_config() {
    if [ ! -d "$CONFIG_DIR" ]; then
        mkdir -p "$CONFIG_DIR"
        echo -e "${GREEN}✓ Created config directory: $CONFIG_DIR${NC}"
    fi

    if [ ! -f "$CONFIG_FILE" ]; then
        echo '{"deployments":{}}' > "$CONFIG_FILE"
        echo -e "${GREEN}✓ Created config file: $CONFIG_FILE${NC}"
    fi
}

# Ensure jq is installed
ensure_jq() {
    if ! command -v jq &> /dev/null; then
        echo -e "${YELLOW}jq is required but not installed.${NC}"
        if [[ "$OSTYPE" == "darwin"* ]]; then
            echo "Install with: brew install jq"
        else
            echo "Install with: sudo apt-get install jq"
        fi
        read -p "Install now? (y/n) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                brew install jq
            else
                sudo apt-get install -y jq
            fi
            echo -e "${GREEN}✓ Installed jq${NC}"
        else
            echo -e "${RED}jq is required. Exiting.${NC}"
            exit 5
        fi
    fi
}

# Check if a deployment exists
deployment_exists() {
    local name="$1"
    local result
    result=$(jq --arg name "$name" -e '.deployments[$name]' "$CONFIG_FILE" 2>/dev/null)
    [ "$result" != "null" ] && [ -n "$result" ]
}

# Get deployment config
get_deployment() {
    local name="$1"
    jq --arg name "$name" -r '.deployments[$name]' "$CONFIG_FILE"
}

# Normalize tool name to ensure it starts with "claude-"
normalize_tool_name() {
    local name="$1"
    name=$(echo "$name" | xargs)
    if [[ ! "$name" =~ ^claude- ]]; then
        name="claude-$name"
    fi
    name=$(echo "$name" | sed 's/^claude-claude-/claude-/')
    echo "$name"
}

# Extract base name from tool name (remove claude- prefix)
get_tool_basename() {
    local name="$1"
    echo "$name" | sed 's/^claude-//'
}

# Validate URL format
validate_url() {
    local url="$1"
    if [[ ! "$url" =~ ^https?:// ]]; then
        echo -e "${RED}Error: URL must start with http:// or https://${NC}"
        return 1
    fi
    return 0
}

# Get list of models for a deployment
get_deployment_models() {
    local name="$1"
    jq -r --arg name "$name" '.deployments[$name].models[]? // .deployments[$name].model // empty' "$CONFIG_FILE" 2>/dev/null
}

# Get default model for a deployment
get_deployment_default_model() {
    local name="$1"
    jq -r --arg name "$name" '.deployments[$name].default_model // .deployments[$name].model // empty' "$CONFIG_FILE" 2>/dev/null
}

# Check if a deployment is using old (single-model) format
is_legacy_deployment() {
    local name="$1"
    jq -e --arg name "$name" '.deployments[$name].model' "$CONFIG_FILE" >/dev/null 2>&1 && \
    ! jq -e --arg name "$name" '.deployments[$name].models' "$CONFIG_FILE" >/dev/null 2>&1
}

# Migrate legacy deployment to multi-model format
migrate_deployment_to_multi() {
    local name="$1"
    local current_model
    current_model=$(jq -r --arg name "$name" '.deployments[$name].model' "$CONFIG_FILE")

    # Check if model is empty or null
    if [ -z "$current_model" ] || [ "$current_model" = "null" ]; then
        echo -e "${RED}Error: No model found in deployment${NC}" >&2
        return 1
    fi

    if ! jq --arg name "$name" --arg model "$current_model" \
        '.deployments[$name].models = [$model] | .deployments[$name].default_model = $model | del(.deployments[$name].model)' \
        "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to migrate deployment to multi-model format${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        return 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        return 1
    fi
    return 0
}

# Ensure Claude Code is installed
ensure_claude_code() {
    if [ ! -f "$CLAUDE_MODEL_DIR/node_modules/.bin/claude" ]; then
        echo -e "${YELLOW}Claude Code not found. Installing...${NC}"
        mkdir -p "$CLAUDE_MODEL_DIR"

        local original_dir="$(pwd)"
        cd "$CLAUDE_MODEL_DIR"

        if [ ! -f "package.json" ]; then
            npm init -y > /dev/null 2>&1
        fi

        if ! npm install @anthropic-ai/claude-code; then
            echo -e "${RED}Error: Failed to install Claude Code${NC}"
            cd "$original_dir"
            exit 1
        fi
        echo -e "${GREEN}✓ Installed Claude Code${NC}"

        cd "$original_dir"
    fi
}

# Configure PATH for the user's shell
configure_path() {
    # Detect shell (reuse logic from deploy-claude-custom.sh)
    local detected_shell=""
    local shell_rc=""

    if [ -n "$SHELL" ]; then
        detected_shell=$(basename "$SHELL")
    fi

    if [ -z "$detected_shell" ] && command -v ps >/dev/null 2>&1; then
        detected_shell=$(ps -p $$ -o comm= 2>/dev/null | xargs basename 2>/dev/null || echo "")
    fi

    case "$detected_shell" in
        zsh)
            shell_rc="$HOME/.zshrc"
            ;;
        bash)
            if [[ "$OSTYPE" == "darwin"* ]]; then
                shell_rc="$HOME/.bash_profile"
                [ ! -f "$shell_rc" ] && shell_rc="$HOME/.bashrc"
            else
                shell_rc="$HOME/.bashrc"
                [ ! -f "$shell_rc" ] && shell_rc="$HOME/.bash_profile"
            fi
            ;;
        fish)
            shell_rc="$HOME/.config/fish/config.fish"
            ;;
        *)
            shell_rc="$HOME/.zshrc"
            ;;
    esac

    local path_line='export PATH="$HOME/.claude-custom/bin:$PATH"'

    if [ "$detected_shell" = "fish" ]; then
        path_line='set -gx PATH $HOME/.claude-custom/bin $PATH'
        mkdir -p "$(dirname "$shell_rc")"
    fi

    [ ! -f "$shell_rc" ] && touch "$shell_rc"

    # Check for old PATH entry and replace it, or add new one
    if grep -q "claude-model/bin" "$shell_rc" 2>/dev/null; then
        # Replace old PATH entry with new one
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' '/claude-model\/bin/d' "$shell_rc"
        else
            sed -i '/claude-model\/bin/d' "$shell_rc"
        fi
        echo "" >> "$shell_rc"
        echo "# Claude Custom Models" >> "$shell_rc"
        echo "$path_line" >> "$shell_rc"
        echo -e "${GREEN}✓ Updated PATH in $shell_rc${NC}"
        echo -e "${YELLOW}Run: source $shell_rc${NC}"
    elif ! grep -q ".claude-custom/bin" "$shell_rc" 2>/dev/null; then
        echo "" >> "$shell_rc"
        echo "# Claude Custom Models" >> "$shell_rc"
        echo "$path_line" >> "$shell_rc"
        echo -e "${GREEN}✓ Added to PATH in $shell_rc${NC}"
        echo -e "${YELLOW}Run: source $shell_rc${NC}"
    fi
}

# Write wrapper script for a deployment
write_wrapper_script() {
    local tool_name="$1"
    local api_key="$2"
    local base_url="$3"
    local default_model="$4"

    local script_path="$BIN_DIR/$tool_name"

    cat > "$script_path" << WRAPPER_EOF
#!/usr/bin/env bash
# Wrapper for Claude Code CLI using custom model API
# Generated by claude-custom
# Tool: $tool_name
# Default Model: $default_model

CLAUDE_BIN="\HOME/claude-model/node_modules/.bin/claude"

# Check if Claude Code is installed
if [ ! -f "\$CLAUDE_BIN" ]; then
    echo "Error: Claude Code not found"
    echo "Please run: claude-custom add $tool_name"
    exit 1
fi

# Determine which model to use
# Priority: 1) --use-model flag, 2) CLAUDE_MODEL env var, 3) default_model
SELECTED_MODEL="$default_model"
CLEANED_ARGS=()

while [[ \$# -gt 0 ]]; do
    case "\$1" in
        --use-model)
            if [[ -n "\$2" && ! "\$2" =~ ^- ]]; then
                SELECTED_MODEL="\$2"
                shift 2
            else
                echo "Error: --use-model requires a model name" >&2
                exit 1
            fi
            ;;
        *)
            CLEANED_ARGS+=("\$1")
            shift
            ;;
    esac
done

# Allow override via environment variable
if [ -n "\$CLAUDE_MODEL" ]; then
    SELECTED_MODEL="\$CLAUDE_MODEL"
fi

# Inject API credentials
export ANTHROPIC_AUTH_TOKEN="$api_key"
export ANTHROPIC_BASE_URL="$base_url"
export ANTHROPIC_MODEL="\$SELECTED_MODEL"

# Keep a separate config dir for this tool
export CLAUDE_CONFIG_DIR="\$HOME/claude-model/.$tool_name"

exec "\$CLAUDE_BIN" "\${CLEANED_ARGS[@]}"
WRAPPER_EOF

    chmod +x "$script_path"
}

# Main entry point
main() {
    local command="$1"
    shift || true

    case "$command" in
        add)
            cmd_add "$@"
            ;;
        remove)
            cmd_remove "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        models)
            cmd_models "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        upgrade)
            cmd_upgrade "$@"
            ;;
        test)
            cmd_test "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        export)
            cmd_export "$@"
            ;;
        import)
            cmd_import "$@"
            ;;
        doctor)
            cmd_doctor "$@"
            ;;
        uninstall)
            cmd_uninstall "$@"
            ;;
        self-update)
            cmd_self_update "$@"
            ;;
        --help|-h|"")
            show_help
            ;;
        --version|-v)
            show_version
            ;;
        *)
            echo -e "${RED}Unknown command: $command${NC}"
            echo "Run 'claude-custom --help' for usage"
            exit 2
            ;;
    esac
}

