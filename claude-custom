#!/usr/bin/env bash
# Claude Custom Manager - Manage custom Claude Code deployments
# Usage: claude-custom <command> [options]

set -e  # Exit on error

# Version
VERSION="1.0.0"

# Configuration
CONFIG_DIR="$HOME/.claude-custom"
CONFIG_FILE="$CONFIG_DIR/config.json"
CLAUDE_MODEL_DIR="$HOME/claude-model"
BIN_DIR="$CLAUDE_MODEL_DIR/bin"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Initialize configuration directory and file
init_config() {
    if [ ! -d "$CONFIG_DIR" ]; then
        mkdir -p "$CONFIG_DIR"
        echo -e "${GREEN}✓ Created config directory: $CONFIG_DIR${NC}"
    fi

    if [ ! -f "$CONFIG_FILE" ]; then
        echo '{"deployments":{}}' > "$CONFIG_FILE"
        echo -e "${GREEN}✓ Created config file: $CONFIG_FILE${NC}"
    fi
}

# Ensure jq is installed
ensure_jq() {
    if ! command -v jq &> /dev/null; then
        echo -e "${YELLOW}jq is required but not installed.${NC}"
        if [[ "$OSTYPE" == "darwin"* ]]; then
            echo "Install with: brew install jq"
        else
            echo "Install with: sudo apt-get install jq"
        fi
        read -p "Install now? (y/n) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                brew install jq
            else
                sudo apt-get install -y jq
            fi
            echo -e "${GREEN}✓ Installed jq${NC}"
        else
            echo -e "${RED}jq is required. Exiting.${NC}"
            exit 5
        fi
    fi
}

# Check if a deployment exists
deployment_exists() {
    local name="$1"
    local result
    result=$(jq --arg name "$name" -e '.deployments[$name]' "$CONFIG_FILE" 2>/dev/null)
    [ "$result" != "null" ] && [ -n "$result" ]
}

# Get deployment config
get_deployment() {
    local name="$1"
    jq --arg name "$name" -r '.deployments[$name]' "$CONFIG_FILE"
}

# Normalize tool name to ensure it starts with "claude-"
normalize_tool_name() {
    local name="$1"
    name=$(echo "$name" | xargs)
    if [[ ! "$name" =~ ^claude- ]]; then
        name="claude-$name"
    fi
    name=$(echo "$name" | sed 's/^claude-claude-/claude-/')
    echo "$name"
}

# Extract base name from tool name (remove claude- prefix)
get_tool_basename() {
    local name="$1"
    echo "$name" | sed 's/^claude-//'
}

# Validate URL format
validate_url() {
    local url="$1"
    if [[ ! "$url" =~ ^https?:// ]]; then
        echo -e "${RED}Error: URL must start with http:// or https://${NC}"
        return 1
    fi
    return 0
}

# Ensure Claude Code is installed
ensure_claude_code() {
    if [ ! -f "$CLAUDE_MODEL_DIR/node_modules/.bin/claude" ]; then
        echo -e "${YELLOW}Claude Code not found. Installing...${NC}"
        mkdir -p "$CLAUDE_MODEL_DIR"

        local original_dir="$(pwd)"
        cd "$CLAUDE_MODEL_DIR"

        if [ ! -f "package.json" ]; then
            npm init -y > /dev/null 2>&1
        fi

        if ! npm install @anthropic-ai/claude-code; then
            echo -e "${RED}Error: Failed to install Claude Code${NC}"
            cd "$original_dir"
            exit 1
        fi
        echo -e "${GREEN}✓ Installed Claude Code${NC}"

        cd "$original_dir"
    fi
}

# Configure PATH for the user's shell
configure_path() {
    # Detect shell (reuse logic from deploy-claude-custom.sh)
    local detected_shell=""
    local shell_rc=""

    if [ -n "$SHELL" ]; then
        detected_shell=$(basename "$SHELL")
    fi

    if [ -z "$detected_shell" ] && command -v ps >/dev/null 2>&1; then
        detected_shell=$(ps -p $$ -o comm= 2>/dev/null | xargs basename 2>/dev/null || echo "")
    fi

    case "$detected_shell" in
        zsh)
            shell_rc="$HOME/.zshrc"
            ;;
        bash)
            if [[ "$OSTYPE" == "darwin"* ]]; then
                shell_rc="$HOME/.bash_profile"
                [ ! -f "$shell_rc" ] && shell_rc="$HOME/.bashrc"
            else
                shell_rc="$HOME/.bashrc"
                [ ! -f "$shell_rc" ] && shell_rc="$HOME/.bash_profile"
            fi
            ;;
        fish)
            shell_rc="$HOME/.config/fish/config.fish"
            ;;
        *)
            shell_rc="$HOME/.zshrc"
            ;;
    esac

    local path_line='export PATH="$HOME/claude-model/bin:$PATH"'

    if [ "$detected_shell" = "fish" ]; then
        path_line='set -gx PATH $HOME/claude-model/bin $PATH'
        mkdir -p "$(dirname "$shell_rc")"
    fi

    [ ! -f "$shell_rc" ] && touch "$shell_rc"

    if ! grep -q "claude-model/bin" "$shell_rc" 2>/dev/null; then
        echo "" >> "$shell_rc"
        echo "# Claude Custom Models" >> "$shell_rc"
        echo "$path_line" >> "$shell_rc"
        echo -e "${GREEN}✓ Added to PATH in $shell_rc${NC}"
        echo -e "${YELLOW}Run: source $shell_rc${NC}"
    fi
}

# Write wrapper script for a deployment
write_wrapper_script() {
    local tool_name="$1"
    local api_key="$2"
    local base_url="$3"
    local model="$4"

    local script_path="$BIN_DIR/$tool_name"

    cat > "$script_path" << WRAPPER_EOF
#!/usr/bin/env bash
# Wrapper for Claude Code CLI using custom model API
# Generated by claude-custom
# Tool: $tool_name
# Model: $model

CLAUDE_BIN="\$HOME/claude-model/node_modules/.bin/claude"

# Check if Claude Code is installed
if [ ! -f "\$CLAUDE_BIN" ]; then
    echo "Error: Claude Code not found"
    echo "Please run: claude-custom add $tool_name"
    exit 1
fi

# Inject API credentials
export ANTHROPIC_AUTH_TOKEN="$api_key"
export ANTHROPIC_BASE_URL="$base_url"
export ANTHROPIC_MODEL="$model"

# Keep a separate config dir for this tool
export CLAUDE_CONFIG_DIR="\$HOME/claude-model/.$tool_name"

exec "\$CLAUDE_BIN" "\$@"
WRAPPER_EOF

    chmod +x "$script_path"
}

# Main entry point
main() {
    local command="$1"
    shift || true

    case "$command" in
        add)
            cmd_add "$@"
            ;;
        remove)
            cmd_remove "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        upgrade)
            cmd_upgrade "$@"
            ;;
        self-update)
            cmd_self_update "$@"
            ;;
        --help|-h|"")
            show_help
            ;;
        --version|-v)
            show_version
            ;;
        *)
            echo -e "${RED}Unknown command: $command${NC}"
            echo "Run 'claude-custom --help' for usage"
            exit 2
            ;;
    esac
}

show_help() {
    cat << EOF
claude-custom - Manage custom Claude Code deployments

Usage: claude-custom <command> [options]

Commands:
  add          Add a new custom model deployment
  remove       Remove a deployment
  list         List all deployments
  update       Update a deployment configuration
  upgrade      Upgrade Claude Code to latest version
  self-update  Update claude-custom itself

Options:
  --help, -h     Show this help message
  --version, -v  Show version

Run 'claude-custom <command> --help' for more info on a command.
EOF
}

show_version() {
    echo "claude-custom $VERSION"
}

show_add_help() {
    cat << EOF
Add a new custom model deployment

Usage: claude-custom add <name> [options]

Arguments:
  <name>                  Name for the deployment (auto-prefixed with claude-)

Options:
  --api-key, -k <KEY>     API key for the model provider
  --base-url, -u <URL>    Base URL for the API endpoint
  --model, -m <MODEL>     Model name to use

Examples:
  claude-custom add doubao
  claude-custom add glm --api-key sk-xxx --base-url https://api.example.com/v1 --model glm-4
EOF
}

show_remove_help() {
    cat << EOF
Remove a deployment

Usage: claude-custom remove <name>

Arguments:
  <name>                  Name of the deployment to remove

Examples:
  claude-custom remove doubao
EOF
}

show_list_help() {
    cat << EOF
List all deployments

Usage: claude-custom list
EOF
}

show_update_help() {
    cat << EOF
Update a deployment

Usage: claude-custom update <name> [options]

Arguments:
  <name>                  Name of the deployment to update

Options:
  --api-key, -k <KEY>     New API key
  --base-url, -u <URL>    New base URL
  --model, -m <MODEL>     New model name

Examples:
  claude-custom update doubao --model glm-4-6
  claude-custom update glm --api-key sk-new-key
EOF
}

show_upgrade_help() {
    cat << EOF
Upgrade Claude Code

Usage: claude-custom upgrade [name]

Arguments:
  <name>                  (Optional) Name of deployment to check after upgrade

Options:
  --latest, -l            Install latest version (npm install @anthropic-ai/claude-code@latest)

Examples:
  claude-custom upgrade
  claude-custom upgrade --latest
  claude-custom upgrade doubao
EOF
}

show_self_update_help() {
    cat << EOF
Update claude-custom itself

Usage: claude-custom self-update

Downloads the latest version of claude-custom from GitHub and
replaces the current installation.

Examples:
  claude-custom self-update
EOF
}


# Command implementations
cmd_add() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_add_help
        exit 0
    fi

    local tool_name=""
    local api_key=""
    local base_url=""
    local model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --api-key|-k)
                api_key="$2"
                shift 2
                ;;
            --base-url|-u)
                base_url="$2"
                shift 2
                ;;
            --model|-m)
                model="$2"
                shift 2
                ;;
            *)
                if [ -z "$tool_name" ]; then
                    tool_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    # Initialize
    init_config
    ensure_jq
    ensure_claude_code

    # Get tool name
    if [ -z "$tool_name" ]; then
        read -p "Tool name: " tool_name
        if [ -z "$tool_name" ]; then
            echo -e "${RED}Error: Tool name is required${NC}"
            exit 2
        fi
    fi

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")

    # Validate tool name
    if [[ ! "$tool_name" =~ ^claude-[a-zA-Z0-9-]+$ ]]; then
        echo -e "${RED}Error: Tool name must start with 'claude-' and contain only letters, numbers, and hyphens${NC}"
        exit 2
    fi

    # Check if deployment exists
    local basename
    basename=$(get_tool_basename "$tool_name")
    if deployment_exists "$basename"; then
        echo -e "${YELLOW}Deployment '$tool_name' already exists${NC}"
        echo -e "${YELLOW}Use 'claude-custom update $basename' to modify it${NC}"
        exit 1
    fi

    # Get API key
    if [ -z "$api_key" ]; then
        read -p "API Key: " api_key
        if [ -z "$api_key" ]; then
            echo -e "${RED}Error: API Key is required${NC}"
            exit 2
        fi
    fi

    # Get base URL
    if [ -z "$base_url" ]; then
        read -p "Base URL: " base_url
        if [ -z "$base_url" ]; then
            echo -e "${RED}Error: Base URL is required${NC}"
            exit 2
        fi
    fi

    # Validate URL
    if ! validate_url "$base_url"; then
        exit 2
    fi

    # Get model name
    if [ -z "$model" ]; then
        read -p "Model name: " model
        if [ -z "$model" ]; then
            echo -e "${RED}Error: Model name is required${NC}"
            exit 2
        fi
    fi

    # Create bin directory
    mkdir -p "$BIN_DIR"

    # Write wrapper script
    write_wrapper_script "$tool_name" "$api_key" "$base_url" "$model"

    # Save to config
    local basename=$(get_tool_basename "$tool_name")
    if ! jq --arg name "$basename" \
       --arg api_key "$api_key" \
       --arg base_url "$base_url" \
       --arg model "$model" \
       '.deployments[$name] = {api_key: $api_key, base_url: $base_url, model: $model}' \
       "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi

    # Configure PATH
    configure_path

    # Create tool config directory
    mkdir -p "$CLAUDE_MODEL_DIR/.$tool_name"

    echo -e "${GREEN}✓ Added $tool_name${NC}"
    echo "  Run: source ~/.zshrc  # or your shell config"
    echo "  Use: $tool_name"
}

cmd_remove() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_remove_help
        exit 0
    fi

    local tool_name="$1"

    if [ -z "$tool_name" ]; then
        echo -e "${RED}Error: Tool name is required${NC}"
        echo "Usage: claude-custom remove <name>"
        exit 2
    fi

    init_config
    ensure_jq

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")
    local basename
    basename=$(get_tool_basename "$tool_name")

    # Check if deployment exists
    if ! deployment_exists "$basename"; then
        echo -e "${RED}Error: Deployment '$tool_name' not found${NC}"
        echo ""
        echo "Run 'claude-custom list' to see available deployments"
        exit 1
    fi

    # Confirm removal
    read -p "Remove $tool_name? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi

    # Remove wrapper script
    local wrapper_path="$BIN_DIR/$tool_name"
    if [ -f "$wrapper_path" ]; then
        rm -f "$wrapper_path"
        echo -e "${GREEN}✓ Removed wrapper script${NC}"
    fi

    # Remove config directory
    local config_path="$CLAUDE_MODEL_DIR/.$tool_name"
    if [ -d "$config_path" ]; then
        rm -rf "$config_path"
        echo -e "${GREEN}✓ Removed config directory${NC}"
    fi

    # Remove from config
    if ! jq --arg name "$basename" 'del(.deployments[$name])' "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi

    echo -e "${GREEN}✓ Removed $tool_name${NC}"
}

cmd_list() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_list_help
        exit 0
    fi

    init_config
    ensure_jq

    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        echo ""
        echo "Add a deployment with:"
        echo "  claude-custom add <name>"
        return
    fi

    echo "Deployed Models:"
    echo ""
    printf "  %-20s %-40s %-30s %-15s\n" "NAME" "BASE URL" "MODEL" "VERSION"
    echo "  ──────────────────── ──────────────────────────────────────── ───────────────── ─────────────"

    # Get list of deployment names
    local names=()
    while IFS= read -r name; do
        names+=("$name")
    done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")

    # For each deployment, get info and version
    for name in "${names[@]}"; do
        local base_url model
        base_url=$(jq -r ".deployments.\"$name\".base_url" "$CONFIG_FILE")
        model=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")

        # Get Claude version
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"
        local version="N/A"

        if [ -f "$wrapper_path" ]; then
            version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
            # Extract just the version number if possible
            if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                version="${BASH_REMATCH[0]}"
            fi
        fi

        printf "  %-20s %-40s %-30s %-15s\n" "$name" "${base_url:0:40}" "${model:0:30}" "$version"
    done

    echo ""
    echo "Total: $count deployment(s)"
}

cmd_update() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_update_help
        exit 0
    fi

    local tool_name=""
    local new_api_key=""
    local new_base_url=""
    local new_model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --api-key|-k)
                new_api_key="$2"
                shift 2
                ;;
            --base-url|-u)
                new_base_url="$2"
                shift 2
                ;;
            --model|-m)
                new_model="$2"
                shift 2
                ;;
            *)
                if [ -z "$tool_name" ]; then
                    tool_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    if [ -z "$tool_name" ]; then
        echo -e "${RED}Error: Tool name is required${NC}"
        echo "Usage: claude-custom update <name> [options]"
        exit 2
    fi

    init_config
    ensure_jq

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")
    local basename
    basename=$(get_tool_basename "$tool_name")

    # Validate tool name
    if [[ ! "$tool_name" =~ ^claude-[a-zA-Z0-9-]+$ ]]; then
        echo -e "${RED}Error: Tool name must start with 'claude-' and contain only letters, numbers, and hyphens${NC}"
        exit 2
    fi

    # Check if deployment exists
    if ! deployment_exists "$basename"; then
        echo -e "${RED}Error: Deployment '$tool_name' not found${NC}"
        echo ""
        echo "Run 'claude-custom list' to see available deployments"
        echo "Or use 'claude-custom add' to create a new deployment"
        exit 1
    fi

    # Get current config
    local current_api_key
    current_api_key=$(jq -r ".deployments.\"$basename\".api_key" "$CONFIG_FILE")
    local current_base_url
    current_base_url=$(jq -r ".deployments.\"$basename\".base_url" "$CONFIG_FILE")
    local current_model
    current_model=$(jq -r ".deployments.\"$basename\".model" "$CONFIG_FILE")

    # Prompt for values to update
    if [ -z "$new_api_key" ]; then
        read -p "API Key [$current_api_key]: " new_api_key
        new_api_key="${new_api_key:-$current_api_key}"
    fi

    if [ -z "$new_api_key" ]; then
        echo -e "${RED}Error: API Key cannot be empty${NC}"
        exit 2
    fi

    if [ -z "$new_base_url" ]; then
        read -p "Base URL [$current_base_url]: " new_base_url
        new_base_url="${new_base_url:-$current_base_url}"
    fi

    if [ -z "$new_model" ]; then
        read -p "Model [$current_model]: " new_model
        new_model="${new_model:-$current_model}"
    fi

    # Validate URL if changed
    if [ "$new_base_url" != "$current_base_url" ]; then
        if ! validate_url "$new_base_url"; then
            exit 2
        fi
    fi

    # Update config
    if ! jq --arg name "$basename" \
       --arg api_key "$new_api_key" \
       --arg base_url "$new_base_url" \
       --arg model "$new_model" \
       '.deployments[$name] = {api_key: $api_key, base_url: $base_url, model: $model}' \
       "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi

    # Rewrite wrapper script
    write_wrapper_script "$tool_name" "$new_api_key" "$new_base_url" "$new_model"

    echo -e "${GREEN}✓ Updated $tool_name${NC}"
}

cmd_upgrade() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_upgrade_help
        exit 0
    fi

    local check_name=""
    local install_latest=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --latest|-l)
                install_latest=true
                shift
                ;;
            *)
                if [ -z "$check_name" ]; then
                    check_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    init_config

    # Check if we have deployments
    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE" 2>/dev/null || echo "0")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        echo ""
        echo "Add a deployment first with:"
        echo "  claude-custom add <name>"
        exit 1
    fi

    echo "Upgrading Claude Code..."
    echo ""

    # Get current version before upgrade
    local old_version="unknown"
    if [ -f "$CLAUDE_BIN" ]; then
        old_version=$("$CLAUDE_BIN" --version 2>/dev/null || echo "unknown")
    fi

    echo "Current version: $old_version"
    echo ""

    # Change to the claude-model directory
    if ! cd "$CLAUDE_MODEL_DIR" 2>/dev/null; then
        echo -e "${RED}Error: Claude Code directory not found: $CLAUDE_MODEL_DIR${NC}"
        exit 1
    fi

    # Run npm install to upgrade
    echo "Running: npm install @anthropic-ai/claude-code${install_latest:+@latest}..."
    echo ""

    if ! npm install @anthropic-ai/claude-code${install_latest:+@latest} 2>&1; then
        echo ""
        echo -e "${RED}Error: Failed to upgrade Claude Code${NC}"
        exit 1
    fi

    echo ""
    echo -e "${GREEN}✓ Claude Code upgraded successfully${NC}"

    # Get new version
    local new_version
    new_version=$("$CLAUDE_BIN" --version 2>/dev/null || echo "unknown")

    echo ""
    echo "Old version: $old_version"
    echo "New version: $new_version"
    echo ""

    # Check specific deployment if requested
    if [ -n "$check_name" ]; then
        check_name=$(normalize_tool_name "$check_name")
        local basename
        basename=$(get_tool_basename "$check_name")

        if ! deployment_exists "$basename"; then
            echo -e "${YELLOW}Warning: Deployment '$check_name' not found${NC}"
        else
            echo "Testing $check_name..."
            if "$BIN_DIR/$check_name" --version >/dev/null 2>&1; then
                echo -e "${GREEN}✓ $check_name is working correctly${NC}"
            else
                echo -e "${YELLOW}Warning: $check_name may have issues${NC}"
            fi
        fi
    fi

    # Show all deployments with their versions
    echo ""
    echo "All deployments:"
    echo ""
    printf "  %-20s %-15s\n" "NAME" "VERSION"
    echo "  ──────────────────── ─────────────"

    local names=()
    while IFS= read -r name; do
        names+=("$name")
    done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")

    for name in "${names[@]}"; do
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"
        local version="N/A"

        if [ -f "$wrapper_path" ]; then
            version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
            if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                version="${BASH_REMATCH[0]}"
            fi
        fi

        printf "  %-20s %-15s\n" "$name" "$version"
    done

    echo ""
    echo "Total: $count deployment(s)"
}

cmd_self_update() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_self_update_help
        exit 0
    fi

    # Get current version
    local current_version="$VERSION"

    echo "Updating claude-custom..."
    echo ""
    echo "Current version: $current_version"
    echo ""

    # Determine script location
    local script_path=""
    if [ -L "$0" ]; then
        # Script is a symlink, get the real path
        script_path=$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null)
    else
        script_path="$0"
    fi

    if [ ! -f "$script_path" ]; then
        echo -e "${RED}Error: Cannot determine script location${NC}"
        exit 1
    fi

    # Check if we can write to the script location
    if [ ! -w "$script_path" ]; then
        echo -e "${YELLOW}Warning: No write permission to $script_path${NC}"
        echo ""
        echo "Try running with sudo:"
        echo "  sudo claude-custom self-update"
        exit 1
    fi

    # Get latest release tag from GitHub API
    local repo="${REPO:-SSBun/deploy-custom-claude-code}"
    echo "Checking for latest release..."
    local latest_tag
    latest_tag=$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null | grep -o '"tag_name": *"[^"]*"' | cut -d'"' -f4)

    if [ -z "$latest_tag" ]; then
        echo -e "${YELLOW}Warning: Could not fetch latest tag, falling back to main branch${NC}"
        latest_tag="main"
    fi

    echo "Latest release: $latest_tag"
    echo ""

    # Download URL using the tag
    local download_url="https://raw.githubusercontent.com/$repo/$latest_tag/claude-custom"

    echo "Downloading from: $download_url"
    echo ""

    # Download to temp file
    local temp_file="/tmp/claude-custom.tmp"
    if ! curl -fsSL "$download_url" -o "$temp_file" 2>&1; then
        echo -e "${RED}Error: Failed to download update${NC}"
        rm -f "$temp_file"
        exit 1
    fi

    # Verify the downloaded file is not empty
    if [ ! -s "$temp_file" ]; then
        echo -e "${RED}Error: Downloaded file is empty${NC}"
        rm -f "$temp_file"
        exit 1
    fi

    # Extract version from downloaded file
    local new_version
    new_version=$(grep "^VERSION=" "$temp_file" | head -1 | cut -d'"' -f2)

    if [ -z "$new_version" ]; then
        echo -e "${YELLOW}Warning: Could not determine new version${NC}"
        new_version="unknown"
    fi

    echo "New version: $new_version"
    echo ""

    # Check if already up to date
    if [ "$current_version" == "$new_version" ]; then
        echo "Already up to date!"
        rm -f "$temp_file"
        return 0
    fi

    # Backup current script
    local backup_file="${script_path}.backup"
    echo "Backing up current script to: $backup_file"
    cp "$script_path" "$backup_file"

    # Replace with new version
    echo "Installing new version..."
    if ! mv "$temp_file" "$script_path"; then
        echo -e "${RED}Error: Failed to install update${NC}"
        echo "Restoring backup..."
        mv "$backup_file" "$script_path"
        rm -f "$temp_file"
        exit 1
    fi

    # Make sure it's executable
    chmod +x "$script_path"

    rm -f "$backup_file"

    echo ""
    echo -e "${GREEN}✓ Updated successfully!${NC}"
    echo ""
    echo "Changes:"
    echo "  Previous version: $current_version"
    echo "  New version:      $new_version"
    echo ""
    echo "Run 'claude-custom --help' to see new features."
}

# Run main
main "$@"
