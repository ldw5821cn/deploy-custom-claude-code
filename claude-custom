    local current_base_url
    current_base_url=$(jq -r ".deployments.\"$basename\".base_url" "$CONFIG_FILE")
    local current_default_model
    current_default_model=$(get_deployment_default_model "$basename")

    # Handle model management operations
    local modified=false

    if [ -n "$add_model" ]; then
        # Add model to the list
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$add_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = true ]; then
            echo -e "${YELLOW}Warning: Model '$add_model' already exists${NC}"
        else
            if ! jq --arg name "$basename" --arg model "$add_model" \
                '.deployments[$name].models += [$model]' \
                "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            echo -e "${GREEN}✓ Added model '$add_model'${NC}"
            modified=true
        fi
    fi

    if [ -n "$remove_model" ]; then
        # Remove model from the list
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$remove_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$remove_model' not found in deployment${NC}"
            exit 1
        fi

        # Check if it's the only model
        local model_count
        model_count=$(get_deployment_models "$basename" | wc -l | xargs)
        if [ "$model_count" -eq 1 ]; then
            echo -e "${RED}Error: Cannot remove the only model${NC}"
            echo "Use 'claude-custom update $basename --model <new-model>' to replace it"
            exit 1
        fi

        # Check if it's the default model
        if [ "$remove_model" = "$current_default_model" ]; then
            echo -e "${RED}Error: Cannot remove the default model${NC}"
            echo "Set a different default first with:"
            echo "  claude-custom update $basename --default-model <model>"
            exit 1
        fi

        # Remove model from the array
        if ! jq --arg name "$basename" --arg model "$remove_model" \
            '.deployments[$name].models |= map(select(. != $model))' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        echo -e "${GREEN}✓ Removed model '$remove_model'${NC}"
        modified=true
    fi

    if [ -n "$default_model" ]; then
        # Set default model
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$default_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$default_model' not found in deployment${NC}"
            echo ""
            echo "Available models:"
            while IFS= read -r model; do
                echo "  - $model"
            done < <(get_deployment_models "$basename")
            exit 1
        fi

        # Update default model
        if ! jq --arg name "$basename" --arg default "$default_model" \
            '.deployments[$name].default_model = $default' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        echo -e "${GREEN}✓ Set default model to '$default_model'${NC}"
        current_default_model="$default_model"
        modified=true
    fi

    if [ -n "$new_model" ]; then
        # Replace all models with new single model
        if ! jq --arg name "$basename" --arg model "$new_model" \
            '.deployments[$name].models = [$model] | .deployments[$name].default_model = $model' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        echo -e "${GREEN}✓ Set model to '$new_model'${NC}"
        current_default_model="$new_model"
        modified=true
    fi

    # If no model operations, prompt for values to update
    if [ "$modified" = false ]; then
        # Prompt for values to update
        if [ -z "$new_api_key" ]; then
            read -p "API Key [$current_api_key]: " new_api_key
            new_api_key="${new_api_key:-$current_api_key}"
        fi

        if [ -z "$new_api_key" ]; then
            echo -e "${RED}Error: API Key cannot be empty${NC}"
            exit 2
        fi

        if [ -z "$new_base_url" ]; then
            read -p "Base URL [$current_base_url]: " new_base_url
            new_base_url="${new_base_url:-$current_base_url}"
        fi

        # Validate URL if changed
        if [ "$new_base_url" != "$current_base_url" ]; then
            if ! validate_url "$new_base_url"; then
                exit 2
            fi
        fi
    else
        # For model operations, use existing values if not specified
        new_api_key="${new_api_key:-$current_api_key}"
        new_base_url="${new_base_url:-$current_base_url}"
    fi

    # Update config (only if api_key or base_url changed, or if model operations were performed)
    if [ "$modified" = true ] || [ "$new_api_key" != "$current_api_key" ] || [ "$new_base_url" != "$current_base_url" ]; then
        # Get the current models array
        local models_json
        models_json=$(jq -c ".deployments.\"$basename\".models" "$CONFIG_FILE")

        if ! jq --arg name "$basename" \
           --arg api_key "$new_api_key" \
           --arg base_url "$new_base_url" \
           --arg default_model "$current_default_model" \
           --argjson models "$models_json" \
           '.deployments[$name] = {api_key: $api_key, base_url: $base_url, models: $models, default_model: $default_model}' \
           "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
    fi

    # Rewrite wrapper script
    write_wrapper_script "$tool_name" "$new_api_key" "$new_base_url" "$current_default_model"

    # Update 'claude' alias script in ~/.claude-custom/ if it exists
    local claude_script="$CONFIG_DIR/claude"
    if [ -f "$claude_script" ]; then
        cat > "$claude_script" << EOF
#!/usr/bin/env bash
# Wrapper for $tool_name deployment
# Generated by claude-custom

exec "$BIN_DIR/$tool_name" "\$@"
EOF
        chmod +x "$claude_script"
    fi

    if [ "$modified" = false ] && [ "$new_api_key" = "$current_api_key" ] && [ "$new_base_url" = "$current_base_url" ]; then
        echo "No changes made."
    else
        echo -e "${GREEN}✓ Updated $tool_name${NC}"
    fi
}

cmd_upgrade() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_upgrade_help
        exit 0
    fi

    local check_name=""
    local install_latest=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --latest|-l)
                install_latest=true
                shift
                ;;
            *)
                if [ -z "$check_name" ]; then
                    check_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    init_config

    # Check if we have deployments
    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE" 2>/dev/null || echo "0")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        echo ""
        echo "Add a deployment first with:"
        echo "  claude-custom add <name>"
        exit 1
    fi

    echo "Upgrading Claude Code..."
    echo ""

    # Get current version before upgrade
    local old_version="unknown"
    if [ -f "$CLAUDE_BIN" ]; then
        old_version=$("$CLAUDE_BIN" --version 2>/dev/null || echo "unknown")
    fi

    echo "Current version: $old_version"
    echo ""

    # Change to the claude-model directory
    if ! cd "$CLAUDE_MODEL_DIR" 2>/dev/null; then
        echo -e "${RED}Error: Claude Code directory not found: $CLAUDE_MODEL_DIR${NC}"
        exit 1
    fi

    # Run npm install to upgrade
    echo "Running: npm install @anthropic-ai/claude-code${install_latest:+@latest}..."
    echo ""

    if ! npm install @anthropic-ai/claude-code${install_latest:+@latest} 2>&1; then
        echo ""
        echo -e "${RED}Error: Failed to upgrade Claude Code${NC}"
        exit 1
    fi

    echo ""
    echo -e "${GREEN}✓ Claude Code upgraded successfully${NC}"

    # Get new version
    local new_version
    new_version=$("$CLAUDE_BIN" --version 2>/dev/null || echo "unknown")

    echo ""
    echo "Old version: $old_version"
    echo "New version: $new_version"
    echo ""

    # Check specific deployment if requested
    if [ -n "$check_name" ]; then
        check_name=$(normalize_tool_name "$check_name")
        local basename
        basename=$(get_tool_basename "$check_name")

        if ! deployment_exists "$basename"; then
            echo -e "${YELLOW}Warning: Deployment '$check_name' not found${NC}"
        else
            echo "Testing $check_name..."
            if "$BIN_DIR/$check_name" --version >/dev/null 2>&1; then
                echo -e "${GREEN}✓ $check_name is working correctly${NC}"
            else
                echo -e "${YELLOW}Warning: $check_name may have issues${NC}"
            fi
        fi
    fi

    # Show all deployments with their versions
    echo ""
    echo "All deployments:"
    echo ""
    printf "  %-20s %-15s\n" "NAME" "VERSION"
    echo "  ──────────────────── ─────────────"

    local names=()
    while IFS= read -r name; do
        names+=("$name")
    done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")

    for name in "${names[@]}"; do
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"
        local version="N/A"

        if [ -f "$wrapper_path" ]; then
            version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
            if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                version="${BASH_REMATCH[0]}"
            fi
        fi

        printf "  %-20s %-15s\n" "$name" "$version"
    done

    echo ""
    echo "Total: $count deployment(s)"
}

cmd_self_update() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_self_update_help
        exit 0
    fi

    # Get current version
    local current_version="$VERSION"

    echo "Updating claude-custom..."
    echo ""
    echo "Current version: $current_version"
    echo ""

    # Determine script location
    local script_path=""
    if [ -L "$0" ]; then
        # Script is a symlink, get the real path
        script_path=$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null)
    else
        script_path="$0"
    fi

    if [ ! -f "$script_path" ]; then
        echo -e "${RED}Error: Cannot determine script location${NC}"
        exit 1
    fi

    # Check if we can write to the script location
    if [ ! -w "$script_path" ]; then
        echo -e "${YELLOW}Warning: No write permission to $script_path${NC}"
        echo ""
        echo "Try running with sudo:"
        echo "  sudo claude-custom self-update"
        exit 1
    fi

    # Get latest release tag from GitHub API
    local repo="${REPO:-SSBun/deploy-custom-claude-code}"
    echo "Checking for latest release..."
    local latest_tag
    latest_tag=$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null | grep -o '"tag_name": *"[^"]*"' | cut -d'"' -f4)

    if [ -z "$latest_tag" ]; then
        echo -e "${YELLOW}Warning: Could not fetch latest tag, falling back to main branch${NC}"
        latest_tag="main"
    fi

    echo "Latest release: $latest_tag"
    echo ""

    # Download URL using the tag
    local download_url="https://raw.githubusercontent.com/$repo/$latest_tag/claude-custom"

    echo "Downloading from: $download_url"
    echo ""

    # Download to temp file
    local temp_file="/tmp/claude-custom.tmp"
    if ! curl -fsSL "$download_url" -o "$temp_file" 2>&1; then
        echo -e "${RED}Error: Failed to download update${NC}"
        rm -f "$temp_file"
        exit 1
    fi

    # Verify the downloaded file is not empty
    if [ ! -s "$temp_file" ]; then
        echo -e "${RED}Error: Downloaded file is empty${NC}"
        rm -f "$temp_file"
        exit 1
    fi

    # Extract version from downloaded file
    local new_version
    new_version=$(grep "^VERSION=" "$temp_file" | head -1 | cut -d'"' -f2)

    if [ -z "$new_version" ]; then
        echo -e "${YELLOW}Warning: Could not determine new version${NC}"
        new_version="unknown"
    fi

    echo "New version: $new_version"
    echo ""

    # Check if already up to date
    if [ "$current_version" == "$new_version" ]; then
        echo "Already up to date!"
        rm -f "$temp_file"
        return 0
    fi

    # Backup current script
    local backup_file="${script_path}.backup"
    echo "Backing up current script to: $backup_file"
    cp "$script_path" "$backup_file"

    # Replace with new version
    echo "Installing new version..."
    if ! mv "$temp_file" "$script_path"; then
        echo -e "${RED}Error: Failed to install update${NC}"
        echo "Restoring backup..."
        mv "$backup_file" "$script_path"
        rm -f "$temp_file"
        exit 1
    fi

    # Make sure it's executable
    chmod +x "$script_path"

    rm -f "$backup_file"

    echo ""
    echo -e "${GREEN}✓ Updated successfully!${NC}"
    echo ""
    echo "Changes:"
    echo "  Previous version: $current_version"
    echo "  New version:      $new_version"
    echo ""
    echo "Run 'claude-custom --help' to see new features."
}

cmd_config() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_config_help
        exit 0
    fi

    init_config

    local action="${1:-show}"

    case "$action" in
        show)
            echo "Configuration file: $CONFIG_FILE"
            echo ""
            if [ -f "$CONFIG_FILE" ]; then
                cat "$CONFIG_FILE"
            else
                echo "Config file does not exist"
            fi
            ;;
        edit)
            if [ ! -f "$CONFIG_FILE" ]; then
                echo -e "${YELLOW}Config file does not exist. Creating...${NC}"
                echo '{"deployments":{}}' > "$CONFIG_FILE"
            fi

            # Use EDITOR or VISUAL, fallback to common editors
            local editor="${EDITOR:-${VISUAL:-}}"
            if [ -z "$editor" ]; then
                if command -v code &>/dev/null; then
                    editor="code --wait"
                elif command -v vim &>/dev/null; then
                    editor="vim"
                elif command -v nano &>/dev/null; then
                    editor="nano"
                else
                    editor="vi"
                fi
            fi

            echo "Editing: $CONFIG_FILE"
            echo "Editor: $editor"
            $editor "$CONFIG_FILE"

            # Validate after edit
            echo ""
            if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
                echo -e "${RED}Warning: Config file has invalid JSON syntax${NC}"
                echo "Please fix the syntax before using claude-custom."
                exit 1
            fi

            echo -e "${GREEN}✓ Config file is valid${NC}"
            ;;
        validate)
            echo "Validating: $CONFIG_FILE"
            echo ""
            if [ ! -f "$CONFIG_FILE" ]; then
                echo -e "${RED}Error: Config file does not exist${NC}"
                exit 1
            fi

            if jq empty "$CONFIG_FILE" 2>/dev/null; then
                echo -e "${GREEN}✓ Config file is valid JSON${NC}"

                local count
                count=$(jq '.deployments | length' "$CONFIG_FILE")
                echo "Deployments: $count"

                if [ "$count" -gt 0 ]; then
                    echo ""
                    jq -r '.deployments | keys[]' "$CONFIG_FILE" | while read -r name; do
                        local model
                        model=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")
                        echo "  - $name ($model)"
                    done
                fi
            else
                echo -e "${RED}Error: Config file has invalid JSON syntax${NC}"
                jq empty "$CONFIG_FILE" 2>&1 | head -5
                exit 1
            fi
            ;;
        *)
            echo "Configuration file: $CONFIG_FILE"
            ;;
    esac
}

cmd_test() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_test_help
        exit 0
    fi

    init_config
    ensure_jq

    local test_all=false
    local verbose=false
    local test_api=false
    local target_name=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --all|-a)
                test_all=true
                shift
                ;;
            --verbose|-v)
                verbose=true
                shift
                ;;
            --api|-c)
                test_api=true
                shift
                ;;
            *)
                if [ -z "$target_name" ]; then
                    target_name="$1"
                fi
                shift
                ;;
        esac
    done

    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        exit 1
    fi

    # If no target specified and not testing all, require a name
    if [ "$test_all" = false ] && [ -z "$target_name" ]; then
        echo -e "${RED}Error: Specify a deployment name or use --all${NC}"
        echo ""
        echo "Usage: claude-custom test <name>"
        echo "   or: claude-custom test --all"
        exit 2
    fi

    local names=()
    if [ "$test_all" = true ]; then
        while IFS= read -r name; do
            names+=("$name")
        done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")
    else
        target_name=$(get_tool_basename "$(normalize_tool_name "$target_name")")
        if ! deployment_exists "$target_name"; then
            echo -e "${RED}Error: Deployment '$target_name' not found${NC}"
            exit 1
        fi
        names+=("$target_name")
    fi

    echo "Testing deployment(s)..."
    echo ""

    local passed=0
    local failed=0

    for name in "${names[@]}"; do
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"

        echo -n "Testing $tool_name... "

        if [ ! -f "$wrapper_path" ]; then
            echo -e "${RED}FAIL${NC}"
            echo "  Wrapper script not found: $wrapper_path"
            ((failed++))
            [ "$verbose" = true ] && echo ""
            continue
        fi

        if [ ! -x "$wrapper_path" ]; then
            echo -e "${RED}FAIL${NC}"
            echo "  Wrapper script is not executable"
            ((failed++))
            [ "$verbose" = true ] && echo ""
            continue
        fi

        # Get version
        local version="N/A"
        version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
        if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
            version="${BASH_REMATCH[0]}"
        fi

        # Test API connectivity if requested
        if [ "$test_api" = true ]; then
            local api_key base_url model
            api_key=$(jq -r ".deployments.\"$name\".api_key" "$CONFIG_FILE")
            base_url=$(jq -r ".deployments.\"$name\".base_url" "$CONFIG_FILE")
            model=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")

            echo -n "API... "

            # Quick connectivity test using curl
            local api_url="${base_url%/}/v1/messages"
            local api_result
            api_result=$(curl -s -X POST "$api_url" \
                -H "x-api-key: $api_key" \
                -H "anthropic-version: 2023-06-01" \
                -H "content-type: application/json" \
                -d '{
                    "model": "'"$model"'",
                    "max_tokens": 10,
                    "messages": [{"role": "user", "content": "hi"}]
                }' \
                --max-time 10 2>&1)
            local curl_exit=$?

            if [ $curl_exit -ne 0 ]; then
                # Curl failed to connect
                echo -e "${RED}FAIL${NC}"
                echo "  Version: $version"
                echo "  API: ${RED}Connection failed${NC}"
                if [ "$verbose" = true ]; then
                    echo "  Error: $api_result"
                fi
                ((failed++))
            elif ! echo "$api_result" | jq empty >/dev/null 2>&1; then
                # Response is not valid JSON
                echo -e "${RED}FAIL${NC}"
                echo "  Version: $version"
                echo "  API: ${RED}Invalid response${NC}"
                if [ "$verbose" = true ]; then
                    echo "  Response: $api_result"
                fi
                ((failed++))
            elif echo "$api_result" | jq -e '.error' >/dev/null 2>&1; then
                # API returned an error
                local error_type
                error_type=$(echo "$api_result" | jq -r '.error.type // .error' 2>/dev/null)
                if [[ "$error_type" == *"authentication"* ]] || [[ "$error_type" == *"auth"* ]]; then
                    echo -e "${RED}FAIL${NC}"
                    echo "  Version: $version"
                    echo "  API: ${RED}Auth Error${NC} (check API key)"
                    ((failed++))
                else
                    echo -e "${YELLOW}WARN${NC}"
                    echo "  Version: $version"
                    echo "  API: ${YELLOW}API Error ($error_type)${NC}"
                    ((failed++))
                fi
            else
                # Success!
                echo -e "${GREEN}PASS${NC}"
                echo "  Version: $version"
                echo "  API: ${GREEN}Connected${NC}"
                ((passed++))
            fi

            if [ "$verbose" = true ]; then
                echo "  Base URL: $base_url"
                echo "  Model: $model"
                echo "  Wrapper: $wrapper_path"
                echo ""
            fi
        else
            echo -e "${GREEN}PASS${NC}"
            echo "  Version: $version"
            echo "  API: Skipped (use --api to test)"
            ((passed++))

            if [ "$verbose" = true ]; then
                # Show wrapper details
                local base_url model
                base_url=$(jq -r ".deployments.\"$name\".base_url" "$CONFIG_FILE")
                model=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")
                echo "  Base URL: $base_url"
                echo "  Model: $model"
                echo "  Wrapper: $wrapper_path"
                echo ""
            fi
        fi
    done

    echo ""
    echo "Results: $passed passed, $failed failed"

    if [ $failed -gt 0 ]; then
        exit 1
    fi
}

cmd_export() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_export_help
        exit 0
    fi

    init_config
    ensure_jq

    local output_file="${1:-}"

    if [ -z "$output_file" ]; then
        # Output to stdout
        jq '.' "$CONFIG_FILE"
    else
        # Output to file
        if cp "$CONFIG_FILE" "$output_file" 2>/dev/null; then
            echo -e "${GREEN}✓ Exported to $output_file${NC}"
        else
            echo -e "${RED}Error: Failed to export to $output_file${NC}"
            exit 1
        fi
    fi
}

cmd_import() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_import_help
        exit 0
    fi

    init_config
    ensure_jq

    local merge=false
    local dry_run=false
    local input_file=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --merge|-m)
                merge=true
                shift
                ;;
            --dry-run|-n)
                dry_run=true
                shift
                ;;
            *)
                if [ -z "$input_file" ]; then
                    input_file="$1"
                fi
                shift
                ;;
        esac
    done

    # Read input
    local import_data
    if [ -n "$input_file" ]; then
        if [ ! -f "$input_file" ]; then
            echo -e "${RED}Error: File not found: $input_file${NC}"
            exit 1
        fi
        import_data=$(cat "$input_file")
    else
        # Read from stdin
        import_data=$(cat)
    fi

    # Validate JSON
    if ! echo "$import_data" | jq empty 2>/dev/null; then
        echo -e "${RED}Error: Invalid JSON data${NC}"
        exit 1
    fi

    # Check for deployments key
    if ! echo "$import_data" | jq -e '.deployments' >/dev/null 2>&1; then
        echo -e "${RED}Error: Missing 'deployments' key in import data${NC}"
        exit 1
    fi

    local import_count
    import_count=$(echo "$import_data" | jq '.deployments | length')

    echo "Found $import_count deployment(s) to import"
    echo ""

    if [ "$dry_run" = true ]; then
        echo "Deployments to be imported:"
        echo "$import_data" | jq -r '.deployments | keys[]' | while read -r name; do
            local model
            model=$(echo "$import_data" | jq -r ".deployments.\"$name\".model")
            echo "  - $name ($model)"
        done
        echo ""
        echo "Dry run complete. No changes made."
        exit 0
    fi

    # Perform import
    if [ "$merge" = true ]; then
        # Merge with existing config
        echo "Merging with existing configuration..."

        # Get current deployments
        local current_data
        current_data=$(cat "$CONFIG_FILE")

        # Merge deployments
        local merged_data
        merged_data=$(jq -s '.[0].deployments * .[1].deployments | {deployments: .}' <(echo "$current_data") <(echo "$import_data"))

        if ! echo "$merged_data" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to merge configurations${NC}"
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update configuration${NC}"
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        echo -e "${GREEN}✓ Merged $import_count deployment(s)${NC}"
    else
        # Replace entire config
        echo "Replacing configuration..."
        if ! echo "$import_data" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to write configuration${NC}"
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update configuration${NC}"
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        echo -e "${GREEN}✓ Imported $import_count deployment(s)${NC}"
    fi

    echo ""
    echo "Current deployments:"
    cmd_list --help 2>/dev/null || echo "  Run 'claude-custom list' to see all deployments"
}

cmd_doctor() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_doctor_help
        exit 0
    fi

    echo "Claude Custom Doctor - Diagnosing issues..."
    echo ""

    local issues=0

    # Check 1: jq installation
    echo -n "Checking jq installation... "
    if command -v jq &>/dev/null; then
        local jq_version
        jq_version=$(jq --version 2>/dev/null)
        echo -e "${GREEN}OK${NC} ($jq_version)"
    else
        echo -e "${RED}FAIL${NC}"
        echo "  jq is not installed"
        echo "  Install with: brew install jq (macOS) or apt-get install jq (Linux)"
        ((issues++))
    fi

    # Check 2: Node.js and npm
    echo -n "Checking Node.js installation... "
    if command -v node &>/dev/null; then
        local node_version
        node_version=$(node --version 2>/dev/null)
        echo -e "${GREEN}OK${NC} ($node_version)"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  Node.js is not installed (required for Claude Code)"
        ((issues++))
    fi

    echo -n "Checking npm installation... "
    if command -v npm &>/dev/null; then
        local npm_version
        npm_version=$(npm --version 2>/dev/null)
        echo -e "${GREEN}OK${NC} ($npm_version)"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  npm is not installed (required for Claude Code)"
        ((issues++))
    fi

    # Check 3: Claude Code installation
    echo -n "Checking Claude Code installation... "
    if [ -f "$CLAUDE_BIN" ]; then
        local claude_version
        claude_version=$("$CLAUDE_BIN" --version 2>/dev/null || echo "unknown")
        echo -e "${GREEN}OK${NC} ($claude_version)"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  Claude Code is not installed"
        echo "  Run: cd ~/claude-model && npm install @anthropic-ai/claude-code"
        ((issues++))
    fi

    # Check 4: Config directory
    echo -n "Checking config directory... "
    if [ -d "$CONFIG_DIR" ]; then
        echo -e "${GREEN}OK${NC} ($CONFIG_DIR)"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  Config directory does not exist (will be created on first use)"
    fi

    # Check 5: Config file validity
    echo -n "Checking config file validity... "
    if [ -f "$CONFIG_FILE" ]; then
        if jq empty "$CONFIG_FILE" 2>/dev/null; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAIL${NC}"
            echo "  Config file has invalid JSON"
            echo "  Run: claude-custom config validate"
            ((issues++))
        fi
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  Config file does not exist"
    fi

    # Check 6: PATH configuration
    echo -n "Checking PATH configuration... "
    if echo "$PATH" | grep -q "$HOME/claude-model/bin"; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  ~/claude-model/bin is not in PATH"
        echo "  Add it: export PATH=\"\$HOME/claude-model/bin:\$PATH\""
        ((issues++))
    fi

    # Check 7: Deployment wrappers
    echo -n "Checking deployment wrappers... "
    local wrapper_count=0
    local broken_wrappers=0
    if [ -d "$BIN_DIR" ]; then
        while IFS= read -r wrapper; do
            ((wrapper_count++))
            if [ ! -x "$wrapper" ]; then
                ((broken_wrappers++))
            fi
        done < <(find "$BIN_DIR" -name "claude-*" -type f 2>/dev/null)
    fi

    if [ $wrapper_count -gt 0 ]; then
        if [ $broken_wrappers -eq 0 ]; then
            echo -e "${GREEN}OK${NC} ($wrapper_count wrappers)"
        else
            echo -e "${YELLOW}WARN${NC} ($wrapper_count wrappers, $broken_wrappers broken)"
            echo "  Run: chmod +x ~/claude-model/bin/claude-*"
            ((issues++))
        fi
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  No deployment wrappers found"
    fi

    # Check 8: Network connectivity (optional)
    echo -n "Checking GitHub connectivity... "
    if curl -fsSL --connect-timeout 5 "https://api.github.com" >/dev/null 2>&1; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${YELLOW}WARN${NC}"
        echo "  Cannot reach GitHub (self-update may not work)"
        ((issues++))
    fi

    # Summary
    echo ""
    echo "Diagnosis complete."
    if [ $issues -eq 0 ]; then
        echo -e "${GREEN}No issues found!${NC}"
    else
        echo -e "${YELLOW}Found $issues issue(s)${NC}"
    fi
}

cmd_uninstall() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_uninstall_help
        exit 0
    fi

    local remove_all=false
    local force=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --all|-a)
                remove_all=true
                shift
                ;;
            --force|-f)
                force=true
                shift
                ;;
            *)
                echo -e "${RED}Unknown option: $1${NC}"
                exit 2
                ;;
        esac
    done

    echo "This will remove claude-custom."
    echo ""

    if [ "$remove_all" = true ]; then
        echo "The following will be removed:"
        echo "  - All deployment wrappers in $BIN_DIR"
        echo "  - Configuration in $CONFIG_DIR"
        echo "  - Claude Code installation in $CLAUDE_MODEL_DIR"
        echo ""
    fi

    # Check for sudo if installed system-wide
    local script_path="$0"
    if [[ "$script_path" == "/usr/local/bin/claude-custom" ]]; then
        if [ "$EUID" -ne 0 ]; then
            echo -e "${YELLOW}Note: claude-custom is installed system-wide${NC}"
            echo "Re-run with sudo to remove: sudo claude-custom uninstall"
            exit 1
        fi
        echo "Will remove: /usr/local/bin/claude-custom"
    fi

    # Confirm
    if [ "$force" = false ]; then
        read -p "Continue? (y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 0
        fi
    fi

    echo ""
    echo "Uninstalling..."

    # Remove all deployments if requested
    if [ "$remove_all" = true ]; then
        echo "Removing deployment wrappers..."
        if [ -d "$BIN_DIR" ]; then
            rm -f "$BIN_DIR"/claude-* 2>/dev/null
            echo -e "${GREEN}✓ Removed wrappers${NC}"
        fi

        echo "Removing configuration..."
        if [ -d "$CONFIG_DIR" ]; then
            rm -rf "$CONFIG_DIR" 2>/dev/null
            echo -e "${GREEN}✓ Removed configuration${NC}"
        fi

        echo "Removing Claude Code installation..."
        if [ -d "$CLAUDE_MODEL_DIR" ]; then
            rm -rf "$CLAUDE_MODEL_DIR" 2>/dev/null
            echo -e "${GREEN}✓ Removed Claude Code${NC}"
        fi
    else
        # Just remove config
        echo "Removing configuration..."
        if [ -d "$CONFIG_DIR" ]; then
            rm -rf "$CONFIG_DIR" 2>/dev/null
            echo -e "${GREEN}✓ Removed configuration${NC}"
        fi
    fi

    # Remove the script itself if installed system-wide
    if [[ "$script_path" == "/usr/local/bin/claude-custom" ]]; then
        echo "Removing claude-custom script..."
        rm -f "/usr/local/bin/claude-custom" 2>/dev/null
        echo -e "${GREEN}✓ Removed claude-custom script${NC}"
    fi

    echo ""
    echo -e "${GREEN}Uninstallation complete!${NC}"
    echo ""
    echo "Note: You may need to remove the PATH configuration from your shell profile:"
    echo "  ~/.zshrc or ~/.bashrc"
    echo ""
    echo "Look for lines containing: claude-model/bin"
}

