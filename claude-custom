# Command implementations
cmd_add() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_add_help
        exit 0
    fi

    local tool_name=""
    local api_key=""
    local base_url=""
    local models=()
    local default_model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --api-key|-k)
                api_key="$2"
                shift 2
                ;;
            --base-url|-u)
                base_url="$2"
                shift 2
                ;;
            --model|-m)
                models+=("$2")
                shift 2
                ;;
            --models)
                # Split comma-separated list
                IFS=',' read -ra MODELS <<< "$2"
                for model in "${MODELS[@]}"; do
                    # Trim whitespace
                    models+=("$(echo "$model" | xargs)")
                done
                shift 2
                ;;
            --default-model)
                default_model="$2"
                shift 2
                ;;
            *)
                if [ -z "$tool_name" ]; then
                    tool_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    # Initialize
    init_config
    ensure_jq
    ensure_claude_code

    # Get tool name
    if [ -z "$tool_name" ]; then
        read -p "Tool name: " tool_name
        if [ -z "$tool_name" ]; then
            echo -e "${RED}Error: Tool name is required${NC}"
            exit 2
        fi
    fi

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")

    # Validate tool name
    if [[ ! "$tool_name" =~ ^claude-[a-zA-Z0-9-]+$ ]]; then
        echo -e "${RED}Error: Tool name must start with 'claude-' and contain only letters, numbers, and hyphens${NC}"
        exit 2
    fi

    # Check if deployment exists
    local basename
    basename=$(get_tool_basename "$tool_name")
    if deployment_exists "$basename"; then
        echo -e "${YELLOW}Deployment '$tool_name' already exists${NC}"
        echo -e "${YELLOW}Use 'claude-custom update $basename' to modify it${NC}"
        exit 1
    fi

    # Get API key
    if [ -z "$api_key" ]; then
        read -p "API Key: " api_key
        if [ -z "$api_key" ]; then
            echo -e "${RED}Error: API Key is required${NC}"
            exit 2
        fi
    fi

    # Get base URL
    if [ -z "$base_url" ]; then
        read -p "Base URL: " base_url
        if [ -z "$base_url" ]; then
            echo -e "${RED}Error: Base URL is required${NC}"
            exit 2
        fi
    fi

    # Validate URL
    if ! validate_url "$base_url"; then
        exit 2
    fi

    # Get model(s) name
    if [ ${#models[@]} -eq 0 ]; then
        read -p "Model name(s) (comma-separated for multiple): " model_input
        if [ -z "$model_input" ]; then
            echo -e "${RED}Error: Model name is required${NC}"
            exit 2
        fi
        # Split comma-separated list
        IFS=',' read -ra MODELS <<< "$model_input"
        for model in "${MODELS[@]}"; do
            models+=("$(echo "$model" | xargs)")
        done
    fi

    # Set default model
    if [ -z "$default_model" ]; then
        default_model="${models[0]}"
    fi

    # Create bin directory
    mkdir -p "$BIN_DIR"

    # Migrate existing wrappers from old location
    local old_bin_dir="$CLAUDE_MODEL_DIR/bin"
    if [ -d "$old_bin_dir" ]; then
        local old_wrappers
        old_wrappers=$(find "$old_bin_dir" -name "claude-*" -type f 2>/dev/null)
        if [ -n "$old_wrappers" ]; then
            echo "Migrating existing wrappers to ~/.claude-custom/bin/..."
            for old_wrapper in $old_wrappers; do
                local wrapper_name
                wrapper_name=$(basename "$old_wrapper")
                if [ ! -f "$BIN_DIR/$wrapper_name" ]; then
                    mv "$old_wrapper" "$BIN_DIR/$wrapper_name" 2>/dev/null
                    echo "  Migrated: $wrapper_name"
                fi
            done
        fi
    fi

    # Write wrapper script
    write_wrapper_script "$tool_name" "$api_key" "$base_url" "$default_model"

    # Save to config
    local basename=$(get_tool_basename "$tool_name")

    # Build JSON for models array
    local models_json="["
    local first=true
    for model in "${models[@]}"; do
        if [ "$first" = true ]; then
            models_json+="\"$model\""
            first=false
        else
            models_json+=",\"$model\""
        fi
    done
    models_json+="]"

    if ! jq --arg name "$basename" \
       --arg api_key "$api_key" \
       --arg base_url "$base_url" \
       --arg default_model "$default_model" \
       --argjson models "$models_json" \
       '.deployments[$name] = {api_key: $api_key, base_url: $base_url, models: $models, default_model: $default_model}' \
       "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi

    # Configure PATH
    configure_path

    # Create tool config directory
    mkdir -p "$CLAUDE_MODEL_DIR/.$tool_name"

    # Create 'claude' alias script in ~/.claude-custom/
    local claude_script="$CONFIG_DIR/claude"
    cat > "$claude_script" << EOF
#!/usr/bin/env bash
# Wrapper for $tool_name deployment
# Generated by claude-custom

exec "$BIN_DIR/$tool_name" "\$@"
EOF
    chmod +x "$claude_script"

    echo -e "${GREEN}✓ Added $tool_name${NC}"
    echo "  Created ~/.claude-custom/claude → $tool_name"
    echo ""
    if [ ${#models[@]} -gt 1 ]; then
        echo -e "${GREEN}Available models (${#models[@]}):${NC}"
        for model in "${models[@]}"; do
            if [ "$model" = "$default_model" ]; then
                echo "  * $model (default)"
            else
                echo "    $model"
            fi
        done
        echo ""
        echo -e "${GREEN}Use with specific model:${NC}"
        echo "  ~/.claude-custom/claude --use-model <model> <args>"
        echo ""
    fi
    echo -e "${GREEN}Use right now:${NC}"
    echo "  ~/.claude-custom/claude <args>"
    echo ""
    echo -e "${YELLOW}For convenience, add to PATH:${NC}"
    echo "  export PATH=\"\$HOME/.claude-custom/bin:\$PATH\""
    echo ""
    echo "  Or add this alias to your ~/.zshrc:"
    echo "  alias claude=~/.claude-custom/claude"
}

cmd_remove() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_remove_help
        exit 0
    fi

    local tool_name="$1"

    if [ -z "$tool_name" ]; then
        echo -e "${RED}Error: Tool name is required${NC}"
        echo "Usage: claude-custom remove <name>"
        exit 2
    fi

    init_config
    ensure_jq

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")
    local basename
    basename=$(get_tool_basename "$tool_name")

    # Check if deployment exists
    if ! deployment_exists "$basename"; then
        echo -e "${RED}Error: Deployment '$tool_name' not found${NC}"
        echo ""
        echo "Run 'claude-custom list' to see available deployments"
        exit 1
    fi

    # Confirm removal
    read -p "Remove $tool_name? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi

    # Remove wrapper script
    local wrapper_path="$BIN_DIR/$tool_name"
    if [ -f "$wrapper_path" ]; then
        rm -f "$wrapper_path"
        echo -e "${GREEN}✓ Removed wrapper script${NC}"
    fi

    # Remove config directory
    local config_path="$CLAUDE_MODEL_DIR/.$tool_name"
    if [ -d "$config_path" ]; then
        rm -rf "$config_path"
        echo -e "${GREEN}✓ Removed config directory${NC}"
    fi

    # Remove from config
    if ! jq --arg name "$basename" 'del(.deployments[$name])' "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi
    if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
        echo -e "${RED}Error: Failed to update config file${NC}" >&2
        rm -f "$CONFIG_FILE.tmp"
        exit 1
    fi

    # Remove 'claude' script if this was the last deployment
    local remaining_count
    remaining_count=$(jq '.deployments | length' "$CONFIG_FILE")
    if [ "$remaining_count" -eq 0 ] && [ -f "$CONFIG_DIR/claude" ]; then
        rm -f "$CONFIG_DIR/claude"
        echo -e "${GREEN}✓ Removed ~/.claude-custom/claude${NC}"
    fi

    echo -e "${GREEN}✓ Removed $tool_name${NC}"
}

cmd_list() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_list_help
        exit 0
    fi

    init_config
    ensure_jq

    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        echo ""
        echo "Add a deployment with:"
        echo "  claude-custom add <name>"
        return
    fi

    echo "Deployed Models:"
    echo ""
    printf "  %-20s %-40s %-30s %-15s\n" "NAME" "BASE URL" "MODELS" "VERSION"
    echo "  ──────────────────── ──────────────────────────────────────── ───────────────── ─────────────"

    # Get list of deployment names
    local names=()
    while IFS= read -r name; do
        names+=("$name")
    done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")

    # For each deployment, get info and version
    for name in "${names[@]}"; do
        local base_url models_display default_model model_count
        base_url=$(jq -r ".deployments.\"$name\".base_url" "$CONFIG_FILE")

        # Check if it's a legacy or multi-model deployment
        if is_legacy_deployment "$name"; then
            # Legacy single model
            models_display=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")
            model_count=1
        else
            # Multi-model deployment
            default_model=$(get_deployment_default_model "$name")
            model_count=0
            models_display=""
            while IFS= read -r model; do
                if [ "$model" = "$default_model" ]; then
                    if [ -n "$models_display" ]; then
                        models_display="$models_display, $model*"
                    else
                        models_display="$model*"
                    fi
                else
                    if [ -n "$models_display" ]; then
                        models_display="$models_display, $model"
                    else
                        models_display="$model"
                    fi
                fi
                ((model_count++))
            done < <(get_deployment_models "$name")
        fi

        # Get Claude version
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"
        local version="N/A"

        if [ -f "$wrapper_path" ]; then
            version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
            # Extract just the version number if possible
            if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                version="${BASH_REMATCH[0]}"
            fi
        fi

        # Truncate models display if too long
        local models_truncated="${models_display:0:30}"
        if [ ${#models_display} -gt 30 ]; then
            models_truncated="${models_truncated}..."
        fi

        printf "  %-20s %-40s %-30s %-15s\n" "$name" "${base_url:0:40}" "$models_truncated ($model_count)" "$version"
    done

    echo ""
    echo "  * = default model"
    echo ""
    echo "Total: $count deployment(s)"
    echo ""
    echo "Manage models with:"
    echo "  claude-custom models <name>"
}

cmd_models() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_models_help
        exit 0
    fi

    local tool_name=""
    local set_default=""
    local add_model=""
    local remove_model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --default)
                set_default="$2"
                shift 2
                ;;
            --add)
                add_model="$2"
                shift 2
                ;;
            --remove)
                remove_model="$2"
                shift 2
                ;;
            *)
                if [ -z "$tool_name" ]; then
                    tool_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    if [ -z "$tool_name" ]; then
        echo -e "${RED}Error: Tool name is required${NC}"
        echo "Usage: claude-custom models <name> [action]"
        exit 2
    fi

    init_config
    ensure_jq

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")
    local basename
    basename=$(get_tool_basename "$tool_name")

    # Check if deployment exists
    if ! deployment_exists "$basename"; then
        echo -e "${RED}Error: Deployment '$tool_name' not found${NC}"
        echo ""
        echo "Run 'claude-custom list' to see available deployments"
        exit 1
    fi

    # Check if this is a legacy deployment and migrate if needed
    if is_legacy_deployment "$basename"; then
        echo "Migrating deployment to multi-model format..."
        if ! migrate_deployment_to_multi "$basename"; then
            echo -e "${RED}Error: Failed to migrate deployment${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Migrated to multi-model format${NC}"
        echo ""
    fi

    # Handle actions
    if [ -n "$set_default" ]; then
        # Set default model
        # Check if model exists
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$set_default" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$set_default' not found in deployment${NC}"
            echo ""
            echo "Available models:"
            while IFS= read -r model; do
                echo "  - $model"
            done < <(get_deployment_models "$basename")
            exit 1
        fi

        # Update default model
        if ! jq --arg name "$basename" --arg default "$set_default" \
            '.deployments[$name].default_model = $default' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        # Update wrapper script with new default
        local api_key base_url
        api_key=$(jq -r ".deployments.\"$basename\".api_key" "$CONFIG_FILE")
        base_url=$(jq -r ".deployments.\"$basename\".base_url" "$CONFIG_FILE")
        write_wrapper_script "$tool_name" "$api_key" "$base_url" "$set_default"

        echo -e "${GREEN}✓ Set default model to '$set_default'${NC}"
    fi

    if [ -n "$add_model" ]; then
        # Add model to the list
        # Check if model already exists
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$add_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = true ]; then
            echo -e "${YELLOW}Warning: Model '$add_model' already exists${NC}"
        else
            # Add model to the array
            if ! jq --arg name "$basename" --arg model "$add_model" \
                '.deployments[$name].models += [$model]' \
                "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            echo -e "${GREEN}✓ Added model '$add_model'${NC}"
        fi
    fi

    if [ -n "$remove_model" ]; then
        # Remove model from the list
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$remove_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$remove_model' not found in deployment${NC}"
            exit 1
        fi

        # Check if it's the only model
        local model_count
        model_count=$(get_deployment_models "$basename" | wc -l | xargs)
        if [ "$model_count" -eq 1 ]; then
            echo -e "${RED}Error: Cannot remove the only model${NC}"
            echo "Use 'claude-custom update $basename --model <new-model>' to replace it"
            exit 1
        fi

        # Check if it's the default model
        local default_model
        default_model=$(get_deployment_default_model "$basename")
        if [ "$remove_model" = "$default_model" ]; then
            echo -e "${RED}Error: Cannot remove the default model${NC}"
            echo "Set a different default first with:"
            echo "  claude-custom models $basename --default <model>"
            exit 1
        fi

        # Remove model from the array
        if ! jq --arg name "$basename" --arg model "$remove_model" \
            '.deployments[$name].models |= map(select(. != $model))' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        echo -e "${GREEN}✓ Removed model '$remove_model'${NC}"
    fi

    # If no action specified, just list models
    if [ -z "$set_default" ] && [ -z "$add_model" ] && [ -z "$remove_model" ]; then
        local default_model
        default_model=$(get_deployment_default_model "$basename")

        echo "Models for $tool_name:"
        echo ""

        local count=0
        while IFS= read -r model; do
            if [ "$model" = "$default_model" ]; then
                echo -e "  * $model ${GREEN}(default)${NC}"
            else
                echo "    $model"
            fi
            ((count++))
        done < <(get_deployment_models "$basename")

        echo ""
        echo "Total: $count model(s)"
        echo ""
        echo "Use with:"
        echo "  $tool_name --use-model <model> <args>"
        echo ""
        echo "Manage models:"
        echo "  claude-custom models $basename --default <name>"
        echo "  claude-custom models $basename --add <name>"
        echo "  claude-custom models $basename --remove <name>"
    fi
}

cmd_update() {
